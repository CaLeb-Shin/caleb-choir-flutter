rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: 본인 문서 create만 허용, role/approvalStatus는 관리자만 수정
    match /users/{userId} {
      allow read: if request.auth != null;
      // 본인 최초 생성 (신청 상태 pending, role=null)
      allow create: if request.auth != null && request.auth.uid == userId;
      // 본인 업데이트: 민감한 필드(role, approvalStatus, partLeaderFor, rejectionReason) 변경 불가
      // 단, approvalStatus를 rejected → pending으로 재신청하는 것은 허용
      allow update: if request.auth != null && request.auth.uid == userId &&
        (!(request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'partLeaderFor', 'rejectionReason'])) &&
         (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['approvalStatus']) ||
          (resource.data.approvalStatus == 'rejected' &&
           request.resource.data.approvalStatus == 'pending')));
      // 관리자는 모든 필드 변경 가능
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Attendance sessions - anyone can read, admin can write
    match /attendance_sessions/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Attendance records
    match /attendance/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
    // Posts - anyone can read, author can write
    match /posts/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    // Comments
    match /comments/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    // Announcements - admin only write
    match /announcements/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Videos - admin write, all read
    match /videos/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Sheet music
    match /sheet_music/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Events
    match /events/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Polls
    match /polls/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'part_leader'];
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'part_leader'];
    }
    // Poll votes
    match /poll_votes/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
    }
    // Seating charts
    match /seating_charts/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Seat assignments
    match /seat_assignments/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'part_leader'];
    }
  }
}
